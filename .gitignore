# =============================================================================
# CROCO Forecast — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Daily run directories (generated at runtime, contain large model data)
# Pattern matches DD-MM-YYYY folders
# ---------------------------------------------------------------------------
[0-9][0-9]-[0-9][0-9]-[0-9][0-9][0-9][0-9]/

# Old / archived run directories
OLD_*/
gb_*/

# Old duplicate tooling copies
old_*/
croco_container_files/

# ---------------------------------------------------------------------------
# Large data / model output files
# ---------------------------------------------------------------------------
*.nc
*.nc4
*.grb
*.grb2
*.grib
*.grib2
*.bin
*.dat

# CROCO output and forcing data directories
CROCO_FILES/
SCRATCH/
FORECAST/
DATA/

# ---------------------------------------------------------------------------
# Compiled binaries
# ---------------------------------------------------------------------------
croco
n_croco
*.so
*.a
*.o
*.mod

# ---------------------------------------------------------------------------
# FORECAST_BASE runtime artifacts
# (keep croco_forecast.in config, ignore binaries and backups)
# ---------------------------------------------------------------------------
FORECAST_BASE/croco
FORECAST_BASE/n_croco
FORECAST_BASE/backup_*/
FORECAST_BASE/CROCO_FILES/*
!FORECAST_BASE/CROCO_FILES/croco_grd.nc

# ---------------------------------------------------------------------------
# Log files
# ---------------------------------------------------------------------------
logs/
*.log

# ---------------------------------------------------------------------------
# Python cache and build artifacts
# ---------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# ---------------------------------------------------------------------------
# Environment and editor files
# ---------------------------------------------------------------------------
.env
.env.*
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/

# ---------------------------------------------------------------------------
# Copernicus / credentials (never commit secrets)
# ---------------------------------------------------------------------------
*credentials*
!**/.example_.copernicusmarine-credentials
*password*
*.key
*.pem

# ---------------------------------------------------------------------------
# Explicitly include DATASETS_CROCOTOOLS (static tidal/reference datasets)
# Override the *.nc exclusion above for this directory
# ---------------------------------------------------------------------------
!cp_g_col_croco_pytools/DATASETS_CROCOTOOLS/
!cp_g_col_croco_pytools/DATASETS_CROCOTOOLS/**
